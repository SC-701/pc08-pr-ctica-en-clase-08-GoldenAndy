@page
@model Web.Pages.Productos.IndexModel
@{
    ViewData["Title"] = "Productos";
}

<section class="productos-page py-5">
    <div class="container">
        <div class="productos-hero text-center mb-5">
            <span class="productos-badge">Gestión de inventario</span>
            <h1 class="productos-title mt-3">Catálogo de productos</h1>
            <p class="productos-subtitle mx-auto">
                Consulta, administra y da seguimiento a los productos registrados en el sistema.
            </p>

            <a class="btn btn-productos-primary btn-lg mt-3" asp-page="./Agregar">
                + Agregar producto
            </a>
        </div>

        @if (Model.Productos != null && Model.Productos.Any())
        {
            <div class="row g-4">
                @foreach (var producto in Model.Productos)
                {
                    <div class="col-12 col-md-6 col-xl-4">
                        <div class="card producto-card h-100">
                            <div class="producto-card-header">
                                <h4 class="mb-0">@producto.Nombre</h4>
                            </div>

                            <div class="card-body p-4">
                                <div class="producto-badges mb-3 text-center">
                                    <span class="badge producto-badge-light">@producto.Categoria</span>
                                    <span class="badge producto-badge-info">@producto.SubCategoria</span>
                                </div>

                                <div class="producto-info">
                                    <p class="mb-3">
                                        <strong>Descripción</strong><br />
                                        <span class="text-muted">@producto.Descripcion</span>
                                    </p>

                                    <p class="mb-3">
                                        <strong>Precio</strong><br />
                                        <span class="producto-precio">₡@producto.Precio.ToString("N2")</span>
                                    </p>

                                    <p class="mb-3">
                                        <strong>Stock disponible</strong><br />
                                        <span class="badge @(producto.Stock > 0 ? "producto-stock-ok" : "producto-stock-empty")">
                                            @producto.Stock unidades
                                        </span>
                                    </p>

                                    <p class="mb-0">
                                        <strong>Código de barras</strong><br />
                                        <span class="text-muted">@producto.CodigoBarras</span>
                                    </p>
                                </div>
                            </div>

                            <div class="card-footer producto-card-footer">
                                <div class="d-grid gap-2">
                                    <a class="btn btn-productos-outline" asp-page="./Detalle" asp-route-id="@producto.Id">
                                        Ver detalle
                                    </a>

                                    <div class="d-flex gap-2">
                                        <a class="btn btn-productos-warning flex-fill" asp-page="./Editar" asp-route-id="@producto.Id">
                                            Editar
                                        </a>

                                        <a class="btn btn-productos-danger flex-fill" asp-page="./Eliminar" asp-route-id="@producto.Id">
                                            Eliminar
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="productos-empty-wrapper">
                <div class="card productos-empty-card">
                    <div class="card-body text-center p-5">
                        <div class="productos-empty-icon mb-3">📦</div>
                        <h3 class="productos-empty-title">No hay productos registrados</h3>
                        <p class="productos-empty-text">
                            Aún no se han agregado productos al sistema. Puedes crear el primero desde aquí.
                        </p>
                        <a class="btn btn-productos-primary btn-lg mt-2" asp-page="./Agregar">
                            Crear primer producto
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</section>