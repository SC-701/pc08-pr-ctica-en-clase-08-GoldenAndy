@page
@model Web.Pages.Productos.IndexModel
@{
    ViewData["Title"] = "Productos";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold text-primary">Nuestra Tiendita de Productos</h1>
        <p class="lead text-muted">
            Explora el catálogo disponible y gestiona los productos de forma rápida y sencilla.
        </p>

        <a type="button" class="btn btn-primary btn-lg shadow-sm px-4 mt-3" asp-page="./Agregar">
            + Agregar producto
        </a>
    </div>

    @if (Model.Productos != null && Model.Productos.Any())
    {
        <div class="row g-4">
            @foreach (var producto in Model.Productos)
            {
                <div class="col-12 col-md-6 col-xl-4">
                    <div class="card border-0 shadow-lg h-100 rounded-4 overflow-hidden producto-card">
                        <div class="card-header bg-primary text-white text-center py-3">
                            <h4 class="mb-0 fw-semibold">@producto.Nombre</h4>
                        </div>

                        <div class="card-body p-4">
                            <p class="text-muted mb-3 text-center">
                                <span class="badge bg-light text-dark border me-2">@producto.Categoria</span>
                                <span class="badge bg-info text-dark">@producto.SubCategoria</span>
                            </p>

                            <div class="mb-3">
                                <p class="mb-2">
                                    <strong>Descripción:</strong><br />
                                    <span class="text-secondary">@producto.Descripcion</span>
                                </p>

                                <p class="mb-2">
                                    <strong>Precio:</strong>
                                    <span class="text-success fw-bold">₡@producto.Precio.ToString("N2")</span>
                                </p>

                                <p class="mb-2">
                                    <strong>Stock disponible:</strong>
                                    <span class="badge @(producto.Stock > 0 ? "bg-success" : "bg-danger")">
                                        @producto.Stock unidades
                                    </span>
                                </p>

                                <p class="mb-0">
                                    <strong>Código de barras:</strong><br />
                                    <span class="text-muted">@producto.CodigoBarras</span>
                                </p>
                            </div>
                        </div>

                        <div class="card-footer bg-white border-0 p-4 pt-0">
                            <div class="d-grid gap-2">
                                <a class="btn btn-outline-primary rounded-pill"
                                   asp-page="./Detalle"
                                   asp-route-id="@producto.Id">
                                    Ver detalle
                                </a>

                                <div class="d-flex gap-2">
                                    <a class="btn btn-warning text-white flex-fill rounded-pill"
                                       asp-page="./Editar"
                                       asp-route-id="@producto.Id">
                                        Editar
                                    </a>

                                    <a class="btn btn-danger flex-fill rounded-pill"
                                       asp-page="./Eliminar"
                                       asp-route-id="@producto.Id">
                                        Eliminar
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="d-flex justify-content-center">
            <div class="card shadow-sm border-0 rounded-4 p-4 text-center" style="max-width: 500px;">
                <div class="card-body">
                    <h3 class="text-primary mb-3">No hay productos registrados</h3>
                    <p class="text-muted mb-4">
                        Parece que la tienda todavía está vacía. Agrega tu primer producto para comenzar.
                    </p>
                    <a class="btn btn-primary btn-lg rounded-pill px-4" asp-page="./Agregar">
                        Crear primer producto
                    </a>
                </div>
            </div>
        </div>
    }
</div>

@* Estilos generados con IA para una apariencia llamativa *@
<style>
    .producto-card {
        transition: transform 0.25s ease, box-shadow 0.25s ease;
        background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
    }

    .producto-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 1rem 2rem rgba(0, 0, 0, 0.12) !important;
    }

    .card-header {
        background: linear-gradient(135deg, #0d6efd, #4dabf7) !important;
    }

    .btn-outline-primary:hover,
    .btn-warning:hover,
    .btn-danger:hover,
    .btn-primary:hover {
        transform: scale(1.02);
        transition: 0.2s ease-in-out;
    }
</style>