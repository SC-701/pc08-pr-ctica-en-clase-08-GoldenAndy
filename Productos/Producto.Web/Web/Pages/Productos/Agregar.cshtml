@page
@model Web.Pages.Productos.AgregarModel
@{
    ViewData["Title"] = "Agregar producto";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header text-white py-4" style="background: linear-gradient(135deg, #0d6efd, #4dabf7);">
                    <div class="text-center">
                        <h1 class="h2 mb-1 fw-bold">Agregar producto</h1>
                        <p class="mb-0 opacity-75">Registra un nuevo producto en tu catálogo</p>
                    </div>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold" asp-for="CategoriaSeleccionada">Categoría</label>
                            <select id="categorias"
                                    asp-for="CategoriaSeleccionada"
                                    class="form-select form-select-lg rounded-3"
                                    asp-items="Model.Categorias"
                                    onchange="fetchSubCategorias()">
                                <option value="">Seleccione una categoría</option>
                            </select>
                            <span class="text-danger" asp-validation-for="CategoriaSeleccionada"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold" asp-for="Producto.IdSubCategoria">Subcategoría</label>
                            <select id="subcategorias"
                                    asp-for="Producto.IdSubCategoria"
                                    class="form-select form-select-lg rounded-3"
                                    asp-items="Model.SubCategorias">
                                <option value="">Seleccione una subcategoría</option>
                            </select>
                            <span class="text-danger" asp-validation-for="Producto.IdSubCategoria"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold" asp-for="Producto.Nombre">Nombre</label>
                            <input class="form-control form-control-lg rounded-3" asp-for="Producto.Nombre" placeholder="Ej: Audífonos Gamer" />
                            <span class="text-danger" asp-validation-for="Producto.Nombre"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold" asp-for="Producto.Descripcion">Descripción</label>
                            <textarea class="form-control rounded-3" asp-for="Producto.Descripcion" rows="4" placeholder="Describe el producto"></textarea>
                            <span class="text-danger" asp-validation-for="Producto.Descripcion"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold" asp-for="Producto.Precio">Precio</label>
                                <input class="form-control form-control-lg rounded-3" asp-for="Producto.Precio" placeholder="Ej: 18990" />
                                <span class="text-danger" asp-validation-for="Producto.Precio"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold" asp-for="Producto.Stock">Stock</label>
                                <input class="form-control form-control-lg rounded-3" asp-for="Producto.Stock" placeholder="Ej: 12" />
                                <span class="text-danger" asp-validation-for="Producto.Stock"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold" asp-for="Producto.CodigoBarras">Código de barras</label>
                            <input class="form-control form-control-lg rounded-3" asp-for="Producto.CodigoBarras" placeholder="Ej: 1234567890123" />
                            <span class="text-danger" asp-validation-for="Producto.CodigoBarras"></span>
                        </div>

                        <div class="d-flex flex-column flex-md-row gap-3 justify-content-center">
                            <a class="btn btn-outline-secondary btn-lg rounded-pill px-4" asp-page="./Index">
                                Regresar
                            </a>
                            <button type="submit" class="btn btn-success btn-lg rounded-pill px-4 shadow-sm">
                                Guardar producto
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        async function fetchSubCategorias() {
            const categoriaId = document.getElementById("categorias").value;
            const subCategoriasSelect = document.getElementById("subcategorias");

            subCategoriasSelect.innerHTML = '<option value="">Seleccione una subcategoría</option>';

            if (!categoriaId) {
                return;
            }

            try {
                const respuesta = await fetch(`?handler=ObtenerSubCategorias&idCategoria=${categoriaId}`);
                const subcategorias = await respuesta.json();

                subcategorias.forEach(subcategoria => {
                    const option = document.createElement("option");
                    option.value = subcategoria.id;
                    option.text = subcategoria.nombre;
                    subCategoriasSelect.appendChild(option);
                });
            } catch (error) {
                console.error("Error obteniendo subcategorías", error);
            }
        }
    </script>
}