<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Web</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Web.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        var nombreUsuario = User?.Identity?.Name
        ?? User?.Claims?.FirstOrDefault(c => c.Type == "NombreUsuario")?.Value
        ?? "Usuario";

        var correoUsuario = User?.Claims?.FirstOrDefault(c =>
        c.Type == "Correo" ||
        c.Type == "email" ||
        c.Type == System.Security.Claims.ClaimTypes.Email)?.Value
        ?? "Sin correo";

        var inicial = !string.IsNullOrWhiteSpace(nombreUsuario)
        ? nombreUsuario.Substring(0, 1).ToUpper()
        : "U";
    }

    <header>
        <nav class="navbar navbar-expand-lg app-navbar shadow-sm">
            <div class="container">
                <a class="navbar-brand app-brand" asp-page="/Index">
                    <span class="brand-badge">WP</span>
                    <div class="brand-text">
                        <span class="brand-title">Web Productos</span>
                        <small class="brand-subtitle">Panel administrativo</small>
                    </div>
                </a>

                <button class="navbar-toggler custom-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 nav-links-custom">
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Index">Inicio</a>
                        </li>
                    </ul>

                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <div class="dropdown user-menu">
                            <button class="btn user-menu-btn dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <span class="user-avatar">@inicial</span>
                                <span class="user-summary">
                                    <span class="user-name">@nombreUsuario</span>
                                    <span class="user-role">Sesión activa</span>
                                </span>
                            </button>

                            <ul class="dropdown-menu dropdown-menu-end user-dropdown shadow">
                                <li class="user-dropdown-header">
                                    <div class="user-avatar user-avatar-lg">@inicial</div>
                                    <div>
                                        <div class="dropdown-user-name">@nombreUsuario</div>
                                        <div class="dropdown-user-email">@correoUsuario</div>
                                    </div>
                                </li>

                                <li><hr class="dropdown-divider"></li>

                                <li>
                                    <a class="dropdown-item logout-item" asp-page="/Cuenta/Logout">
                                        Cerrar sesión
                                    </a>
                                </li>
                            </ul>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="page-bg">
        <div class="container main-shell">
            <main role="main" class="main-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="app-footer">
        <div class="container footer-content">
            <span>&copy; 2026 - Web Productos</span>
            <a asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>