@page
@model Web.Pages.Cuenta.AccesoDenegadoModel
@{
    ViewData["Title"] = "Acceso denegado";
}

<section class="denied-page">
    <div class="denied-bg-glow glow-1"></div>
    <div class="denied-bg-glow glow-2"></div>

    <div class="denied-chaos-zone" id="chaosZone"></div>

    <div class="denied-overlay-text" id="deniedOverlay">
        <span class="denied-badge">403</span>
        <h1 class="denied-title">¡Acceso Denegado!</h1>
        <p class="denied-subtitle">
            No tienes permisos para esta área
        </p>

        <div class="denied-actions">
            <a asp-page="/Index" class="btn-denied-back">Regresar</a>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/js/AccesoDenegado.js"></script>
}