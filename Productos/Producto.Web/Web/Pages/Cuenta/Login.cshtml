@page
@model Web.Pages.Cuenta.LoginModel
@{
    ViewData["Title"] = "Iniciar sesión";
}

<section class="login-page">
    <div class="login-orb login-orb-1"></div>
    <div class="login-orb login-orb-2"></div>
    <div class="login-orb login-orb-3"></div>

    <div class="container">
        <div class="row justify-content-center align-items-center min-vh-100 py-5">
            <div class="col-12 col-lg-10 col-xl-9">
                <div class="login-shell">
                    <div class="row g-0 align-items-stretch">
                        <div class="col-12 col-lg-5">
                            <div class="login-brand-panel h-100">
                                <span class="login-badge">Acceso seguro</span>

                                <h1 class="login-brand-title">
                                    Web Productos
                                </h1>

                                <p class="login-brand-text">
                                    Inicia sesión para administrar el catálogo, controlar el inventario
                                    y acceder a las funciones del sistema según tu rol.
                                </p>

                                <div class="login-feature-list">
                                    <div class="login-feature-item">
                                        <span class="login-feature-icon">✓</span>
                                        <span>Gestión de productos</span>
                                    </div>
                                    <div class="login-feature-item">
                                        <span class="login-feature-icon">✓</span>
                                        <span>Control por roles</span>
                                    </div>
                                    <div class="login-feature-item">
                                        <span class="login-feature-icon">✓</span>
                                        <span>Interfaz moderna y segura</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-7">
                            <div class="login-form-panel">
                                <div class="login-form-header text-center text-lg-start">
                                    <span class="login-kicker">Bienvenido</span>
                                    <h2 class="login-title">Iniciar sesión</h2>
                                    <p class="login-subtitle">
                                        Ingresa tus credenciales para continuar.
                                    </p>
                                </div>

                                <form method="post" class="login-form">
                                    <div asp-validation-summary="ModelOnly" class="alert alert-danger login-validation-summary mb-3"></div>

                                    @if (Model.token is not null && Model.token.ValidacionExitosa == false)
                                    {
                                        <div class="login-alert-error mb-3" role="alert">
                                            Credenciales incorrectas. Verifica tu usuario y contraseña.
                                        </div>
                                    }

                                    <div class="mb-3">
                                        <label class="form-label login-label" asp-for="loginInfo.NombreUsuario">Nombre de usuario</label>
                                        <div class="login-input-wrap">
                                            <span class="login-input-icon">👤</span>
                                            <input type="text"
                                                   asp-for="loginInfo.NombreUsuario"
                                                   class="form-control login-input"
                                                   placeholder="Ingresa tu nombre de usuario" />
                                        </div>
                                        <span asp-validation-for="loginInfo.NombreUsuario" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label login-label" asp-for="loginInfo.Password">Contraseña</label>
                                        <div class="login-input-wrap">
                                            <span class="login-input-icon">🔒</span>
                                            <input type="password"
                                                   asp-for="loginInfo.Password"
                                                   class="form-control login-input"
                                                   placeholder="Ingresa tu contraseña" />
                                        </div>
                                        <span asp-validation-for="loginInfo.Password" class="text-danger"></span>
                                    </div>

                                    <div class="login-actions mt-4">
                                        <button class="btn btn-login-primary" type="submit">
                                            Iniciar sesión
                                        </button>
                                    </div>
                                </form>

                                <div class="login-footer-links">
                                    <a asp-page="/Cuenta/Registro">Registrarse</a>
                                    <a href="#!">Olvidó su contraseña</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="login-bottom-note text-center mt-4">
                    Sistema de gestión con autenticación por roles.
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}